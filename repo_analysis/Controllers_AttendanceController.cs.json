    "html": "<html><head><meta name=\"color-scheme\" content=\"light dark\"></head><body><pre style=\"word-wrap: break-word; white-space: pre-wrap;\">using System;\nusing System.Linq;\nusing System.Net;\nusing System.Threading.Tasks;\nusing System.Web.Http;\nusing System.Web.Http.Cors;\nusing AttendanceSystem.DTOs;\nusing AttendanceSystem.Models;\nusing AttendanceSystem.Services;\n\nnamespace AttendanceSystem.Controllers\n{\n    /// <summary>\n    /// Handles attendance events: real-time recording, device sync, queries, reports.\n    /// </summary>\n    [RoutePrefix(\"api/attendance\")]\n    [EnableCors(origins: \"*\", headers: \"*\", methods: \"*\")]\n    public class AttendanceController : ApiController\n    {\n        private readonly IAttendanceService _attendanceService;\n        private readonly IUserService _userService;\n        private readonly IReportService _reportService;\n\n        public AttendanceController(IAttendanceService attendanceService,\n            IUserService userService, IReportService reportService)\n        {\n            _attendanceService = attendanceService;\n            _userService = userService;\n            _reportService = reportService;\n        }\n\n        /// <summary>\n        /// POST: /api/attendance/sync — called by the Python ZKTeco service\n        /// to push batch attendance records from the device.\n        /// </summary>\n        [HttpPost]\n        [Route(\"sync\")]\n        public async Task<IHttpActionResult> SyncAttendanceRecords([FromBody] SyncRequest request)\n        {\n            if (request?.Records == null || request.Records.Count == 0)\n                return BadRequest(\"No records provided\");\n\n            try\n            {\n                var inputs = request.Records.Select(r => new SyncRecordInput\n                {\n                    UserId = r.UserId,\n                    Timestamp = r.Timestamp,\n                    Status = r.Status,\n                    DeviceSerialNumber = r.DeviceSerialNumber ?? request.DeviceSerialNumber,\n                    VerificationType = r.VerificationType,\n                    VerificationScore = r.VerificationScore,\n                    CapturedImage = r.CapturedImage\n                }).ToList();\n\n                var result = await _attendanceService.SyncDeviceRecordsAsync(inputs, request.DeviceSerialNumber);\n\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Message = $\"Synced {result.Inserted} new records ({result.Skipped} duplicates skipped)\",\n                    Data = new\n                    {\n                        inserted = result.Inserted,\n                        skipped = result.Skipped,\n                        total = result.Total,\n                        deviceSerial = request.DeviceSerialNumber\n                    }\n                });\n            }\n            catch (Exception ex)\n            {\n                var msg = ex.Message;\n                var inner = ex.InnerException;\n                while (inner != null)\n                {\n                    msg += \" | \" + inner.GetType().Name + \": \" + inner.Message;\n                    inner = inner.InnerException;\n                }\n                System.Diagnostics.Trace.TraceError(\"Sync failed: \" + ex);\n                return InternalServerError(new Exception(msg, ex));\n            }\n        }\n\n        /// <summary>\n        /// POST: /api/attendance/checkin — record a single attendance event.\n        /// </summary>\n        [HttpPost]\n        [Route(\"checkin\")]\n        public async Task<IHttpActionResult> RecordCheckin([FromBody] CheckinRequest request)\n        {\n            if (request == null || request.UserId == 0)\n                return BadRequest(\"Invalid request: UserId is required\");\n\n            try\n            {\n                if (!Enum.TryParse<CheckinStatus>(request.Status, true, out var status))\n                    return BadRequest($\"Invalid status '{request.Status}'. Use 'CheckIn' or 'CheckOut'\");\n\n                var verification = request.VerificationType.HasValue\n                    ? (VerificationType)request.VerificationType.Value\n                    : VerificationType.FaceRecognition;\n\n                var score = request.VerificationScore ?? 0;\n\n                var record = await _attendanceService.RecordAttendanceAsync(\n                    request.UserId, status, request.CapturedImage,\n                    verification, score);\n\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Message = \"Attendance recorded successfully\",\n                    Data = new\n                    {\n                        id = record.Id,\n                        userId = record.UserId,\n                        timestamp = record.Timestamp,\n                        status = record.Status.ToString(),\n                        verificationType = record.VerificationType.ToString()\n                    }\n                });\n            }\n            catch (InvalidOperationException ex)\n            {\n                return Content(HttpStatusCode.BadRequest, new ApiResponse<object>\n                {\n                    Success = false,\n                    Message = ex.Message\n                });\n            }\n            catch (Exception ex)\n            {\n                return InternalServerError(ex);\n            }\n        }\n\n        /// <summary>\n        /// GET: /api/attendance/today — recent attendance events for live dashboard.\n        /// </summary>\n        [HttpGet]\n        [Route(\"today\")]\n        public async Task<IHttpActionResult> GetTodayAttendance()\n        {\n            try\n            {\n                var records = await _attendanceService.GetTodayAttendanceAsync();\n                var users = await _userService.GetAllUsersAsync();\n                var userMap = users.ToDictionary(u => u.UserId);\n\n                var dtos = records\n                    .OrderByDescending(r => r.Timestamp)\n                    .Select(r => new\n                    {\n                        id = r.Id,\n                        userId = r.UserId,\n                        employeeId = userMap.TryGetValue(r.UserId, out var u) ? u.EmployeeId : null,\n                        userName = userMap.TryGetValue(r.UserId, out u) ? u.Name : null,\n                        department = userMap.TryGetValue(r.UserId, out u) ? u.Department : null,\n                        timestamp = r.Timestamp,\n                        status = r.Status.ToString(),\n                        verificationType = r.VerificationType.ToString(),\n                        verificationScore = r.VerificationScore,\n                        deviceSerialNumber = r.DeviceSerialNumber,\n                        hasImage = r.CaptureedImage != null && r.CaptureedImage.Length > 0\n                    })\n                    .ToList();\n\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Data = dtos\n                });\n            }\n            catch (Exception ex)\n            {\n                return InternalServerError(ex);\n            }\n        }\n\n        /// <summary>\n        /// GET: /api/attendance/summary/{userId}/{date}\n        /// </summary>\n        [HttpGet]\n        [Route(\"summary/{userId}/{date}\")]\n        public async Task<IHttpActionResult> GetDailySummary(int userId, string date)\n        {\n            if (!DateTime.TryParse(date, out var parsedDate))\n                return BadRequest(\"Invalid date format. Use yyyy-MM-dd\");\n\n            try\n            {\n                var summary = await _attendanceService.GetDailyAttendanceSummaryAsync(userId, parsedDate);\n                if (summary == null) return NotFound();\n\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Data = new\n                    {\n                        id = summary.Id,\n                        userId = summary.UserId,\n                        date = summary.Date.ToString(\"yyyy-MM-dd\"),\n                        checkInTime = summary.CheckInTime?.ToString(\"HH:mm:ss\"),\n                        checkOutTime = summary.CheckOutTime?.ToString(\"HH:mm:ss\"),\n                        workDuration = summary.WorkDuration?.ToString(@\"hh\\:mm\\:ss\"),\n                        workHours = summary.WorkDuration?.TotalHours,\n                        status = summary.AttendanceStatus.ToString()\n                    }\n                });\n            }\n            catch (Exception ex)\n            {\n                return InternalServerError(ex);\n            }\n        }\n\n        /// <summary>\n        /// GET: /api/attendance/records/{userId}?startDate=&endDate=\n        /// </summary>\n        [HttpGet]\n        [Route(\"records/{userId}\")]\n        public async Task<IHttpActionResult> GetUserRecords(int userId,\n            [FromUri] string startDate = null, [FromUri] string endDate = null)\n        {\n            try\n            {\n                var start = string.IsNullOrEmpty(startDate)\n                    ? DateTime.UtcNow.AddMonths(-1)\n                    : DateTime.Parse(startDate);\n                var end = string.IsNullOrEmpty(endDate)\n                    ? DateTime.UtcNow\n                    : DateTime.Parse(endDate);\n\n                var records = await _attendanceService.GetUserAttendanceAsync(userId, start, end);\n\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Message = $\"Retrieved {records.Count} records\",\n                    Data = records.Select(r => new\n                    {\n                        id = r.Id,\n                        userId = r.UserId,\n                        timestamp = r.Timestamp.ToString(\"yyyy-MM-dd HH:mm:ss\"),\n                        status = r.Status.ToString(),\n                        verificationType = r.VerificationType.ToString(),\n                        verificationScore = r.VerificationScore,\n                        deviceSerialNumber = r.DeviceSerialNumber\n                    })\n                });\n            }\n            catch (FormatException)\n            {\n                return BadRequest(\"Invalid date format. Use yyyy-MM-dd\");\n            }\n            catch (Exception ex)\n            {\n                return InternalServerError(ex);\n            }\n        }\n\n        /// <summary>\n        /// GET: /api/attendance/report/monthly?year=2024&month=6&department=\n        /// </summary>\n        [HttpGet]\n        [Route(\"report/monthly\")]\n        public async Task<IHttpActionResult> GetMonthlyReport(int year, int month, [FromUri] string department = null)\n        {\n            try\n            {\n                var report = await _reportService.GetMonthlyReportAsync(year, month, department);\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Message = $\"Monthly report for {year}-{month:D2}\",\n                    Data = report\n                });\n            }\n            catch (Exception ex)\n            {\n                return InternalServerError(ex);\n            }\n        }\n\n        /// <summary>\n        /// GET: /api/attendance/report/daily?date=2024-06-15&department=\n        /// </summary>\n        [HttpGet]\n        [Route(\"report/daily\")]\n        public async Task<IHttpActionResult> GetDailyReport([FromUri] string date, [FromUri] string department = null)\n        {\n            if (!DateTime.TryParse(date, out var parsedDate))\n                return BadRequest(\"Invalid date format. Use yyyy-MM-dd\");\n\n            try\n            {\n                var report = await _reportService.GetDailyReportAsync(parsedDate, department);\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Message = $\"Daily report for {parsedDate:yyyy-MM-dd}\",\n                    Data = report.Select(r => new\n                    {\n                        userId = r.UserId,\n                        employeeId = r.EmployeeId,\n                        name = r.Name,\n                        department = r.Department,\n                        date = r.Date.ToString(\"yyyy-MM-dd\"),\n                        checkInTime = r.CheckInTime?.ToString(\"HH:mm:ss\"),\n                        checkOutTime = r.CheckOutTime?.ToString(\"HH:mm:ss\"),\n                        workDuration = r.WorkDuration?.ToString(@\"hh\\:mm\\:ss\"),\n                        status = r.Status.ToString()\n                    })\n                });\n            }\n            catch (Exception ex)\n            {\n                return InternalServerError(ex);\n            }\n        }\n\n        /// <summary>\n        /// GET: /api/attendance/report/user/{userId}?startDate=&endDate=\n        /// </summary>\n        [HttpGet]\n        [Route(\"report/user/{userId}\")]\n        public async Task<IHttpActionResult> GetUserReport(int userId,\n            [FromUri] string startDate = null, [FromUri] string endDate = null)\n        {\n            try\n            {\n                var start = string.IsNullOrEmpty(startDate)\n                    ? DateTime.UtcNow.AddMonths(-1)\n                    : DateTime.Parse(startDate);\n                var end = string.IsNullOrEmpty(endDate)\n                    ? DateTime.UtcNow\n                    : DateTime.Parse(endDate);\n\n                var report = await _reportService.GetUserReportAsync(userId, start, end);\n                if (report == null) return NotFound();\n\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Data = new\n                    {\n                        user = new\n                        {\n                            userId = report.User.UserId,\n                            employeeId = report.User.EmployeeId,\n                            name = report.User.Name,\n                            department = report.User.Department\n                        },\n                        startDate = report.StartDate.ToString(\"yyyy-MM-dd\"),\n                        endDate = report.EndDate.ToString(\"yyyy-MM-dd\"),\n                        presentDays = report.PresentDays,\n                        lateDays = report.LateDays,\n                        absentDays = report.AbsentDays,\n                        earlyLeaveDays = report.EarlyLeaveDays,\n                        halfDays = report.HalfDays,\n                        onLeaveDays = report.OnLeaveDays,\n                        totalWorkHours = Math.Round(report.TotalWorkHours, 2),\n                        summaries = report.Summaries?.Select(s => new\n                        {\n                            date = s.Date.ToString(\"yyyy-MM-dd\"),\n                            checkInTime = s.CheckInTime?.ToString(\"HH:mm:ss\"),\n                            checkOutTime = s.CheckOutTime?.ToString(\"HH:mm:ss\"),\n                            workDuration = s.WorkDuration?.ToString(@\"hh\\:mm\\:ss\"),\n                            status = s.AttendanceStatus.ToString()\n                        })\n                    }\n                });\n            }\n            catch (FormatException)\n            {\n                return BadRequest(\"Invalid date format. Use yyyy-MM-dd\");\n            }\n            catch (Exception ex)\n            {\n                return InternalServerError(ex);\n            }\n        }\n\n        /// <summary>\n        /// GET: /api/attendance/dashboard-stats — KPIs for the live dashboard.\n        /// </summary>\n        [HttpGet]\n        [Route(\"dashboard-stats\")]\n        public async Task<IHttpActionResult> GetDashboardStats()\n        {\n            try\n            {\n                var stats = await _attendanceService.GetDashboardStatsAsync();\n                return Ok(new ApiResponse<object>\n                {\n                    Success = true,\n                    Data = stats\n                });\n            }\n            catch (Exception ex)\n            {\n                return InternalServerError(ex);\n            }\n        }\n    }\n}\n</pre></body></html>",
